# Global
APP_ENV=development
TEAMUP_DOMAIN=localhost

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Postgres in Docker (dev): docker compose -f infra/docker-compose.postgres.yml up -d
DATABASE_URL=postgresql+psycopg2://teamup:teamup@localhost:5432/teamup
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
# Системный администратор: только users.is_system_admin в БД
ENCRYPTION_KEY_BASE64=change-me-32-byte-base64-key

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# Frontend — не задавайте URL на :8000 при npm run dev: Next проксирует /api -> API_PROXY_TARGET
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_FALLBACK_LOCALE=en

# ClickUp
CLICKUP_API_BASE=https://api.clickup.com/api/v2
# Optional lightweight in-process sync scheduler (single backend process / pilot mode).
CLICKUP_SYNC_SCHEDULER_ENABLED=false
CLICKUP_SYNC_INTERVAL_MINUTES=30
CLICKUP_SYNC_INITIAL_DELAY_SECONDS=10

